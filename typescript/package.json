{
  "name": "@cassandragargoyle/api",
  "version": "1.0.0.9",
  "description": "Shared TypeScript API modules for CassandraGargoyle (log package)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./log": {
      "types": "./dist/log/index.d.ts",
      "import": "./dist/log/index.js",
      "require": "./dist/log/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "validate:contracts": "node ../scripts/validate-contracts.mjs",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
