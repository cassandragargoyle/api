{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://cassandragargoyle.org/schemas/vim-extraction-field.schema.json",
	"$version": "1.0.0",
	"title": "VimExtractionField",
	"description": "Extracted field value with provenance, quality metadata, and alternatives",
	"type": "object",
	"required": ["field_id", "value", "data_type", "confidence"],
	"properties": {
		"field_id": {
			"type": "string",
			"description": "Field identifier (from template)"
		},
		"label": {
			"type": "string",
			"description": "Human-readable field label"
		},
		"value": {
			"description": "Extracted and post-processed value"
		},
		"raw_value": {
			"description": "Raw value before post-processing"
		},
		"data_type": {
			"type": "string",
			"description": "Value type",
			"enum": ["string", "integer", "decimal", "date", "boolean", "enum"]
		},
		"confidence": {
			"type": "number",
			"description": "Extraction confidence (0.0-1.0)",
			"minimum": 0.0,
			"maximum": 1.0
		},
		"bbox": {
			"$ref": "#/$defs/BoundingBox"
		},
		"zone_id": {
			"type": "string",
			"description": "Template zone that defined this field"
		},
		"extraction_method": {
			"type": "string",
			"description": "Per-field extraction method override"
		},
		"alternatives": {
			"type": "array",
			"description": "Alternative interpretations",
			"items": {
				"$ref": "#/$defs/Alternative"
			}
		},
		"validation": {
			"$ref": "#/$defs/Validation"
		},
		"revisions": {
			"type": "array",
			"description": "Value change history (ordered by revision number)",
			"items": {
				"$ref": "#/$defs/Revision"
			}
		}
	},
	"additionalProperties": false,
	"$defs": {
		"BoundingBox": {
			"type": "object",
			"description": "Position on source (pixels for images, points for PDF)",
			"required": ["x", "y", "width", "height"],
			"properties": {
				"x": { "type": "number", "description": "Left edge" },
				"y": { "type": "number", "description": "Top edge" },
				"width": { "type": "number", "description": "Width", "minimum": 0 },
				"height": { "type": "number", "description": "Height", "minimum": 0 },
				"right": { "type": "number", "description": "Computed: x + width" },
				"bottom": { "type": "number", "description": "Computed: y + height" }
			},
			"additionalProperties": false
		},
		"Alternative": {
			"type": "object",
			"required": ["value", "confidence"],
			"properties": {
				"value": { "description": "Alternative extracted value" },
				"confidence": {
					"type": "number",
					"minimum": 0.0,
					"maximum": 1.0
				}
			},
			"additionalProperties": false
		},
		"Validation": {
			"type": "object",
			"required": ["status"],
			"properties": {
				"status": {
					"type": "string",
					"enum": ["valid", "warning", "invalid"]
				},
				"rules_applied": {
					"type": "array",
					"items": { "type": "string" }
				},
				"messages": {
					"type": "array",
					"items": { "type": "string" }
				}
			},
			"additionalProperties": false
		},
		"Revision": {
			"type": "object",
			"description": "A single value change event in the audit trail",
			"required": ["revision", "old_value", "new_value", "actor", "reason"],
			"properties": {
				"revision": {
					"type": "integer",
					"description": "Revision number (1-based, sequential)",
					"minimum": 1
				},
				"old_value": {
					"description": "Value before this change"
				},
				"new_value": {
					"description": "Value after this change"
				},
				"actor": {
					"type": "string",
					"description": "Who made the change",
					"enum": ["engine", "operator", "rule", "llm"]
				},
				"actor_id": {
					"type": "string",
					"description": "Specific actor identity (e.g. user:zdenek, rule:normalize_whitespace)"
				},
				"reason": {
					"type": "string",
					"description": "Why the change was made",
					"enum": ["manual_correction", "character_replacement", "normalization", "reextraction", "type_coercion", "validation_fix", "llm_suggestion", "merge_resolution", "other"]
				},
				"comment": {
					"type": "string",
					"description": "Free-text explanation of the change"
				},
				"timestamp": {
					"type": "string",
					"format": "date-time",
					"description": "ISO 8601 timestamp of the change"
				}
			},
			"additionalProperties": false
		},
		"ExtractionTable": {
			"type": "object",
			"description": "A table fragment extracted from a single source/page",
			"required": ["table_id", "columns", "rows"],
			"properties": {
				"table_id": {
					"type": "string",
					"description": "Unique table fragment ID"
				},
				"group_id": {
					"type": "string",
					"description": "Logical table group (for merging fragments across pages)"
				},
				"page_sequence": {
					"type": "integer",
					"description": "Order of this fragment within the group (1-based)",
					"minimum": 1
				},
				"bbox": { "$ref": "#/$defs/BoundingBox" },
				"confidence": {
					"type": "number",
					"minimum": 0.0,
					"maximum": 1.0
				},
				"columns": {
					"type": "array",
					"items": { "$ref": "#/$defs/ColumnDef" },
					"minItems": 1
				},
				"rows": {
					"type": "array",
					"items": { "$ref": "#/$defs/TableRow" }
				}
			},
			"additionalProperties": false
		},
		"ColumnDef": {
			"type": "object",
			"required": ["column_id"],
			"properties": {
				"column_id": { "type": "string" },
				"label": { "type": "string" },
				"data_type": { "type": "string" }
			},
			"additionalProperties": false
		},
		"TableRow": {
			"type": "object",
			"required": ["row_index", "cells"],
			"properties": {
				"row_index": {
					"type": "integer",
					"minimum": 0
				},
				"is_header": {
					"type": "boolean"
				},
				"cells": {
					"type": "array",
					"items": { "$ref": "#/$defs/TableCell" }
				}
			},
			"additionalProperties": false
		},
		"TableCell": {
			"type": "object",
			"required": ["column_id", "value"],
			"properties": {
				"column_id": {
					"type": "string",
					"description": "Reference to column definition"
				},
				"value": {
					"description": "Cell value"
				},
				"raw_value": {
					"description": "Raw value before post-processing"
				},
				"confidence": {
					"type": "number",
					"minimum": 0.0,
					"maximum": 1.0
				},
				"bbox": { "$ref": "#/$defs/BoundingBox" },
				"row_span": {
					"type": "integer",
					"minimum": 1,
					"default": 1
				},
				"col_span": {
					"type": "integer",
					"minimum": 1,
					"default": 1
				},
				"revisions": {
					"type": "array",
					"description": "Value change history",
					"items": {
						"$ref": "#/$defs/Revision"
					}
				}
			},
			"additionalProperties": false
		}
	}
}
