{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://cassandragargoyle.org/schemas/error.schema.json",
	"$version": "1.0.0",
	"title": "Error",
	"description": "Structured error model for Unified AI Task Platform",
	"type": "object",
	"required": ["code", "message"],
	"properties": {
		"code": {
			"type": "string",
			"description": "Machine-readable error code (e.g. 'INVALID_INPUT', 'TIMEOUT', 'PLUGIN_ERROR')"
		},
		"message": {
			"type": "string",
			"description": "Human-readable error description"
		},
		"details": {
			"type": "object",
			"description": "Additional error context and diagnostics",
			"additionalProperties": true
		},
		"retryable": {
			"type": "boolean",
			"description": "Whether the caller should retry this task",
			"default": false
		}
	},
	"additionalProperties": false
}
