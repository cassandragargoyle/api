{
  // Line length: disabled (long lines are allowed)
  "MD013": false,
  // Allow hard tabs inside code blocks (Java/Go code style uses tabs)
  "MD010": {
    "code_blocks": false
  },
  // Docs use a frontmatter `title:` plus a visible H1 heading; do not treat
  // the frontmatter title as a competing top-level heading
  "MD025": {
    "front_matter_title": ""
  }
}
